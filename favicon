<svg width="400" height="260" viewBox="0 0 400 260" xmlns="http://www.w3.org/2000/svg">
  <title>Old City Photo Co. Logo</title>
  <desc>Interlocking OC monogram logo for Old City Photo Co., Knoxville TN</desc>

  <!-- OC Monogram — filled O, outlined C -->
  <text x="28" y="192"
    font-family="Georgia, serif"
    font-size="196"
    font-style="italic"
    font-weight="300"
    fill="#0E0E0C">O</text>

  <text x="102" y="192"
    font-family="Georgia, serif"
    font-size="196"
    font-style="italic"
    font-weight="300"
    fill="none"
    stroke="#0E0E0C"
    stroke-width="1.5">C</text>

  <!-- Hairline rule -->
  <line x1="40" y1="208" x2="360" y2="208" stroke="#0E0E0C" stroke-width="0.5"/>

  <!-- Photo Co. -->
  <text x="200" y="230"
    font-family="Arial, Helvetica, sans-serif"
    font-size="13"
    font-weight="400"
    letter-spacing="5"
    fill="#0E0E0C"
    text-anchor="middle">PHOTO CO.</text>

  <!-- Knoxville TN -->
  <text x="200" y="248"
    font-family="Arial, Helvetica, sans-serif"
    font-size="9"
    letter-spacing="4"
    fill="#6A6860"
    text-anchor="middle">KNOXVILLE · TN</text>

</svg>
